# Example environment variables for docker-compose and backend
# Copy this file to .env and set secure values for production

# Backend (Spring Boot)
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8081

# Database (used by docker-compose backend to connect to PostgreSQL service)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=db_improvement_solutions
DB_USER=postgres
DB_PASSWORD=postgres

# JWT secret for token signing (CHANGE in production)
JWT_SECRET=change-me-please-very-long-random-string

# PostgreSQL container initialization (optional overrides, if you use the bundled postgres service)
POSTGRES_DB=db_improvement_solutions
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Frontend exposed ports (from docker-compose)
FRONTEND_HTTP_PORT=8001
FRONTEND_HTTPS_PORT=8443

# Super Admin seed (used by backend when SPRING_PROFILES_ACTIVE=prod)
SUPER_ADMIN_USERNAME=Javier
SUPER_ADMIN_EMAIL=javierangelmsn@outlook.es
SUPER_ADMIN_PASSWORD=change-me-super-strong
